# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Secrets and production configs
.env
*.env
# All real configs are local-only (institution-specific values).
# Only the example template stays tracked.
config/*.json
!config/*.example.json

# Local-only prod batch launcher (counterpart to the tracked sandbox launcher).
# Tracked sibling: batch/rs_forms_monitor_sandbox.bat
# TODO: commit this from Masedet for parity (separate hygiene task).
batch/rs_forms_monitor_prod.bat

# Runtime logs directory at repo root (in addition to output/logs/ already covered)
logs/

# Data files (user data, never commit)
input/*.tsv
processed/*.tsv

# Output (logs and reports, never commit)
output/logs/*.log
output/reports/*.csv
*.log

# Keep directory structure
!input/.gitkeep
!processed/.gitkeep
!output/.gitkeep
!output/logs/.gitkeep
!output/reports/.gitkeep

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Babysitter SDK
.a5c/node_modules/
